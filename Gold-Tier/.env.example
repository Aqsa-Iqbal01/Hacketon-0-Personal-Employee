# Personal AI Employee - Gold Tier
# Environment Variables Configuration

# ===========================================
# META (Facebook/Instagram) Configuration
# ===========================================
# Get these from Meta Developer Dashboard: https://developers.facebook.com/

META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_ACCESS_TOKEN=your_long_lived_access_token_here
META_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here
META_FACEBOOK_PAGE_ID=your_facebook_page_id_here

# ===========================================
# Twitter/X API Configuration
# ===========================================
# Get these from Twitter Developer Portal: https://developer.twitter.com/

TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here
TWITTER_USER_ID=your_twitter_user_id_here

# ===========================================
# Odoo ERP Configuration
# ===========================================
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_COMPANY_ID=1

# ===========================================
# Google Gmail Configuration
# ===========================================
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here

# ===========================================
# General Configuration
# ===========================================
# Vault path for Obsidian
VAULT_PATH=C:\Users\HAROON TRADERS\Desktop\ar portfolio\Hacketon-Employee\Gold-Tier\Personal AI Employee Vault

# Debug mode (true/false)
DEBUG_MODE=false

# Dry run mode - won't make actual API calls (true/false)
DRY_RUN=false
